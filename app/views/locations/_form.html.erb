<div 
  data-controller="dependent-dropdown"
  data-dependent-dropdown-provinces-url-value="/api/provinces/:country_id"
  data-dependent-dropdown-cities-url-value="/api/cities/:province_id"
  <% if @location.persisted? %>
    data-dependent-dropdown-selected-province-id-value="<%= @location.province_id %>"
    data-dependent-dropdown-selected-city-id-value="<%= @location.city_id %>"
  <% end %>
  class="bg-white rounded-lg shadow-sm p-6"
>
  <div class="space-y-6">
    <div>
      <h2 class="text-xl font-semibold text-gray-900 mb-6">
        <%= @location.persisted? ? 'Edit Location' : 'New Location' %>
      </h2>
    </div>
    <%= form_with(model: @location, local: true, class: "space-y-6") do |form| %>
      <% if @location.errors.any? %>
        <div class="bg-red-50 border border-red-200 rounded-lg p-4">
          <div class="flex">
            <div class="flex-shrink-0">
              <svg class="h-5 w-5 text-red-400" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"/>
              </svg>
            </div>
            <div class="ml-3">
              <h3 class="text-sm font-medium text-red-800">
                There were <%= pluralize(@location.errors.count, "error") %> with your submission:
              </h3>
              <div class="mt-2 text-sm text-red-700">
                <ul class="list-disc list-inside space-y-1">
                  <% @location.errors.full_messages.each do |message| %>
                    <li><%= message %></li>
                  <% end %>
                </ul>
              </div>
            </div>
          </div>
        </div>
      <% end %>
      <div class="grid grid-cols-1 gap-6 sm:grid-cols-2">
        <!-- Location Name -->
        <div class="sm:col-span-2">
          <%= form.label :name, class: "block text-sm font-medium text-gray-700 mb-2" %>
          <%= form.text_field :name, 
              class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors",
              placeholder: "Enter location name" %>
        </div>
        <!-- Country Selection -->
        <div>
          <%= form.label :country_id, "Country", class: "block text-sm font-medium text-gray-700 mb-2" %>
          <%= form.select :country_id, 
              options_from_collection_for_select(@countries, :id, :name, @location.country_id),
              { prompt: "Select Country..." },
              { 
                class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors",
                data: { 
                  dependent_dropdown_target: "country",
                  action: "change->dependent-dropdown#countryChanged"
                }
              } %>
        </div>
        <!-- Province Selection -->
        <div>
          <%= form.label :province_id, "Province/State", class: "block text-sm font-medium text-gray-700 mb-2" %>
          <%= form.select :province_id, 
              @location.country_id.present? ? options_from_collection_for_select(@location.country.provinces, :id, :name, @location.province_id) : [],
              { prompt: "Select Province..." },
              { 
                class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors disabled:bg-gray-100 disabled:cursor-not-allowed",
                disabled: @location.country_id.blank?,
                data: { 
                  dependent_dropdown_target: "province",
                  action: "change->dependent-dropdown#provinceChanged"
                }
              } %>
        </div>
        <!-- City Selection -->
        <div>
          <%= form.label :city_id, "City", class: "block text-sm font-medium text-gray-700 mb-2" %>
          <%= form.select :city_id, 
              @location.province_id.present? ? options_from_collection_for_select(@location.province.cities, :id, :name, @location.city_id) : [],
              { prompt: "Select City..." },
              { 
                class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors disabled:bg-gray-100 disabled:cursor-not-allowed",
                disabled: @location.province_id.blank?,
                data: { 
                  dependent_dropdown_target: "city"
                }
              } %>
        </div>
      </div>
      <!-- Form Actions -->
      <div class="flex items-center justify-end space-x-4 pt-6 border-t border-gray-200">
        <%= link_to locations_path, 
            class: "px-4 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-lg hover:bg-gray-50 transition-colors" do %>
          Cancel
        <% end %>
        <%= form.submit (@location.persisted? ? "Update Location" : "Create Location"),
            class: "px-6 py-2 text-sm font-medium text-white bg-blue-600 border border-transparent rounded-lg hover:bg-blue-700 focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 transition-colors" %>
      </div>
    <% end %>
  </div>
</div>
